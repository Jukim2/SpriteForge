# @imgly/background-removal pins onnxruntime-web@1.21.0 as a peer dep, but we
# intentionally run onnxruntime-web@1.27.0 (public/resources is regenerated to
# match — see scripts/ and resources.json). Strict peer resolution would fail
# npm ci in CI, so relax it the same way local installs do.
legacy-peer-deps=true
